# Immutable image tag every MAL-owned service is pulled at (server, frontend,
# sandbox, and VM rootfs). Set to the full git commit SHA published to GHCR;
# docker-compose.prod.yml fails fast if it is unset. Pin one SHA, not `latest`.
MAL_IMAGE_TAG=replace-with-the-deployed-commit-sha

# Public origin (replace mal.example.com with the deployed apex domain).
APP_BASE_URL=https://mal.example.com

# Sandboxes and the server share mal-sandbox-net in production.
MCP_SERVER_URL=http://server:3050/mcp
DRIVER_HOST_API_BASE_URL=http://server:3000

# Absolute host path, mounted at the identical path inside the server container.
MAL_RUNS_DIR=/home/services/mal/runs

# Use a URL-safe value because Compose embeds it in DATABASE_URL (hex is ideal).
POSTGRES_PASSWORD=replace-with-a-long-random-hex-password
BETTER_AUTH_SECRET=replace-with-at-least-32-random-bytes

# Distinct 32-byte keys encoded as 64 hexadecimal characters.
FORGE_ENCRYPTION_KEY=replace-with-64-hex-characters
OAUTH_CREDENTIALS_ENCRYPTION_KEY=replace-with-different-64-hex-characters

ACME_EMAIL=operator@example.com
# Scoped to Zone:DNS:Edit for this zone; do not use the Cloudflare Global API Key.
CF_DNS_API_TOKEN=replace-with-scoped-cloudflare-token

# Optional fallback credentials for agent harnesses.
# OPENROUTER_API_KEY=
# ANTHROPIC_API_KEY=
# CURSOR_API_KEY=
# OPENAI_API_KEY=

# --- VM sandboxes (Cloud Hypervisor on the amd64 host) ---------------------
# The kernel and rootfs are pulled into a host cache directory by the deployer
# (kernel: pinned upstream cloud-hypervisor release; rootfs: the SHA-tagged
# my-agent-loop-sandbox-vm image, extracted). Point these at the cached files.
VM_KERNEL_PATH=/home/services/mal/vm/bzImage-x86_64
VM_ROOTFS_PATH=/home/services/mal/vm/rootfs.raw
# The host IP the in-VM guest uses to reach the server (driver host-API + MCP).
# On Linux this is the bridge gateway created by scripts/setup-vm-networking.sh.
VM_HOST_BRIDGE_IP=replace-with-the-host-bridge-gateway-ip
# Linux/cloud-hypervisor only: the host TAP device attached to that bridge and
# the guest MAC. Without a TAP device the VM has no NIC and cannot reach the host.
VM_TAP_DEVICE=replace-with-host-tap-device
VM_MAC=replace-with-guest-mac

# --- Deployment notifier (consumed by the deploy-webhook receiver) ----------
# Public host the GitHub Actions notifier POSTs /deploy to, and the high-entropy
# HMAC secret shared with that workflow. Both are owned by the webhook receiver.
# WEBHOOK_BASE_URL=https://webhook.example.com
# DEPLOY_WEBHOOK_SECRET=replace-with-a-high-entropy-shared-secret
