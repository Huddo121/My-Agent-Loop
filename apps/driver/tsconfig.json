{
  "include": ["./src", "./build-sea-lib.d.ts", "./build-sea-lib.d.mts"],
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "./dist",
    "types": ["node"],
    "paths": {
      "@mono/api": ["../../packages/api/src/index.ts"],
      "@mono/api/*": ["../../packages/api/src/*"],
      "@mono/driver-api": ["../../packages/driver-api/src/index.ts"],
      "@mono/driver-api/*": ["../../packages/driver-api/src/*"]
    }
  },
  "references": [
    {
      "path": "../../packages/driver-api"
    },
    {
      "path": "../../packages/api"
    }
  ]
}
