{
  "$schema": "node_modules/@biomejs/biome/configuration_schema.json",
  "formatter": {
    "indentStyle": "space"
  },
  "files": {
    // `.sc` holds local tool state, not source. It is excluded via a global
    // gitignore that `useIgnoreFile` does not read, so exclude it explicitly.
    "includes": ["**", "!.sc"]
  },
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  }
}
