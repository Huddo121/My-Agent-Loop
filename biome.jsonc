{
  "$schema": "node_modules/@biomejs/biome/configuration_schema.json",
  "formatter": {
    "indentStyle": "space"
  },
  "files": {
    // `.sc` holds local tool state, not source. It is excluded via a global
    // gitignore that `useIgnoreFile` does not read, so exclude it explicitly.
    //
    // `apps/server/drizzle` is generated by `drizzle-kit generate` and must
    // match its output byte-for-byte so a migration-consistency check can
    // regenerate and diff it; the formatter must not rewrite it.
    "includes": ["**", "!.sc", "!apps/server/drizzle"]
  },
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  }
}
