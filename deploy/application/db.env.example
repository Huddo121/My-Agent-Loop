# Installed to /etc/my-agent-loop/db.env on deimos with mode 0600.
# Injected into the Postgres container via Compose env_file. The password here
# must match the one embedded in DATABASE_URL in server.env.
POSTGRES_DB=my_agent_loop
POSTGRES_USER=my_agent_loop
POSTGRES_PASSWORD=REPLACE_WITH_POSTGRES_PASSWORD
