# Installed to /opt/my-agent-loop/.env on deimos with mode 0644.
#
# Compose reads THIS file (the project .env) for `${...}` interpolation; values
# in env_file: are NOT available for interpolation. Only non-secret values that
# Compose needs at config time belong here. Runtime secrets go in server.env /
# db.env. MAL_IMAGE_TAG is NOT set here — the deploy script supplies it per run.

# Host path for per-run sandbox working dirs. Used for the server's bind mount
# (host:container at the same path). Keep in sync with MAL_RUNS_DIR in server.env.
MAL_RUNS_DIR=/opt/my-agent-loop/runs

# When true (default), the deploy script extracts the VM base image for the
# deployed SHA into /opt/my-agent-loop/vm/<sha> and repoints `current`, in-band
# with the app. Set to false to skip VM artifact handling on hosts that only run
# Docker sandboxes.
MAL_VM_ENABLED=true
