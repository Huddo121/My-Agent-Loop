#!/usr/bin/env bash
# Refresh the VM sandbox artifact cache from a published image.
#
# The VM rootfs + kernel are distributed as a FROM scratch image
# (ghcr.io/huddo121/my-agent-loop-sandbox-vm:<sha>) built by the publish
# workflow. This command pulls one SHA, extracts the artifacts into a
# version-pinned directory, and atomically repoints the `current` symlink that
# VM_KERNEL_PATH / VM_ROOTFS_PATH reference.
#
# It is intentionally NOT part of the app deploy: the VM base image rotates
# independently. New VM sandboxes pick up `current`; sandboxes already running
# keep the file they booted from. Run this when the selected VM artifact changes,
# then (optionally) prune old versions once no sandbox references them.
#
# Usage: sudo refresh-vm-image <40-char-commit-sha>
set -Eeuo pipefail

readonly version="${1:-}"
readonly vm_root="${VM_CACHE_ROOT:-/opt/my-agent-loop/vm}"
readonly image="ghcr.io/huddo121/my-agent-loop-sandbox-vm:${version}"

if [[ ! "${version}" =~ ^[0-9a-f]{40}$ ]]; then
  echo "refresh-vm-image: expected a 40-character lowercase commit SHA" >&2
  exit 64
fi

target_dir="${vm_root}/${version}"
install -d -m 0755 "${vm_root}"
install -d -m 0755 "${target_dir}"

# Pull and extract via a throwaway container (the scratch image has no runnable
# command, so create + cp, never run).
docker pull "${image}"
container_id="$(docker create "${image}")"
trap 'docker rm -f "${container_id}" >/dev/null 2>&1 || true' EXIT

docker cp "${container_id}:/rootfs.raw" "${target_dir}/rootfs.raw"
docker cp "${container_id}:/bzImage-x86_64" "${target_dir}/bzImage-x86_64"

# Atomically swap the `current` symlink so an in-progress VM boot never sees a
# half-written file: write a temp link, then rename over the old one.
ln -sfn "${target_dir}" "${vm_root}/current.tmp"
mv -T "${vm_root}/current.tmp" "${vm_root}/current"

echo "refresh-vm-image: ${vm_root}/current -> ${version}"
