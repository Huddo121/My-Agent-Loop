# Installed to /etc/my-agent-loop/server.env on deimos with mode 0600.
# Injected into the server container via Compose env_file. These values stay only
# on the host and must never be committed.

# --- Datastores -------------------------------------------------------------
# Must match db.env. The host name is the Compose service on app-net.
DATABASE_URL=postgres://my_agent_loop:REPLACE_WITH_POSTGRES_PASSWORD@my-agent-loop-db:5432/my_agent_loop
REDIS_HOST=my-agent-loop-redis
REDIS_PORT=6379

# --- Public origin ----------------------------------------------------------
APP_BASE_URL=https://loop.incredibleplatform.com

# --- Sandbox-facing private endpoints --------------------------------------
# Agent sandboxes reach the server over mal-sandbox-net by service DNS, not via
# Traefik. Do not use host.docker.internal in production.
MCP_SERVER_URL=http://server:3050/mcp
DRIVER_HOST_API_BASE_URL=http://server:3000

# Host path for per-run working dirs, bind-mounted into the server at the same
# absolute path (see compose volumes). Also set MAL_RUNS_DIR in the project .env
# so Compose can interpolate the mount path.
MAL_RUNS_DIR=/opt/my-agent-loop/runs

# --- Secrets (generate distinct high-entropy values) -----------------------
BETTER_AUTH_SECRET=REPLACE_WITH_AT_LEAST_32_RANDOM_BYTES
# Distinct 32-byte keys as 64 hex chars; the two must differ.
FORGE_ENCRYPTION_KEY=REPLACE_WITH_64_HEX_CHARS
OAUTH_CREDENTIALS_ENCRYPTION_KEY=REPLACE_WITH_DIFFERENT_64_HEX_CHARS

# --- Optional harness fallback credentials ---------------------------------
# OPENROUTER_API_KEY=
# ANTHROPIC_API_KEY=
# CURSOR_API_KEY=
# OPENAI_API_KEY=

# --- VM sandboxes (Cloud Hypervisor on the amd64 host) ---------------------
# Kernel + rootfs are extracted from the my-agent-loop-sandbox-vm:<sha> image by
# `refresh-vm-image`, which points the `current` symlink at the active version.
VM_KERNEL_PATH=/opt/my-agent-loop/vm/current/bzImage-x86_64
VM_ROOTFS_PATH=/opt/my-agent-loop/vm/current/rootfs.raw
# Host bridge gateway IP the in-VM guest uses to reach the server, plus the TAP
# device and guest MAC (see scripts/setup-vm-networking.sh).
VM_HOST_BRIDGE_IP=REPLACE_WITH_HOST_BRIDGE_GATEWAY_IP
VM_TAP_DEVICE=REPLACE_WITH_HOST_TAP_DEVICE
VM_MAC=REPLACE_WITH_GUEST_MAC
