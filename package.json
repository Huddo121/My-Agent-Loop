{
  "name": "my-agent-loop",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "type": "module",
  "packageManager": "pnpm@10.8.0",
  "scripts": {
    "check": "biome check .",
    "check:fix": "biome check . --write",
    "check:native-builds": "pnpm --filter @mono/scripts check-native-builds",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "dev": "node scripts/dev-env.mjs",
    "dev:isolated": "node scripts/dev-env.mjs --isolated",
    "dev:isolated:down": "node scripts/dev-env.mjs --down",
    "dev:moon": "moon :dev",
    "docker:build": "pnpm driver:build:linux && docker build -t my-agent-loop .",
    "vm:build-rootfs": "bash scripts/build-vm-rootfs.sh",
    "vm:smoke-test": "bash scripts/vm-smoke-test.sh",
    "driver:build": "moon driver:build",
    "driver:build:bundle": "moon driver:build-bundle",
    "driver:build:linux": "moon driver:build-linux",
    "driver:build:sea": "moon driver:build-sea",
    "drizzle": "pnpm run --filter @mono/server drizzle",
    "mal": "pnpm --filter @mono/mal-cli exec tsx src/index.ts",
    "mal:build": "moon mal-cli:build",
    "mal:build:bundle": "moon mal-cli:build-bundle",
    "mal:build:linux": "moon mal-cli:build-linux",
    "mal:build:sea": "moon mal-cli:build-sea",
    "mal:codex:login": "pnpm mal -- providers login codex",
    "mal:codex:logout": "pnpm mal -- providers logout codex",
    "mal:login": "pnpm mal -- login",
    "mal:logout": "pnpm mal -- logout",
    "mal:status": "pnpm mal -- status",
    "portless:clean": "portless clean",
    "portless:list": "portless list",
    "portless:trust": "portless trust",
    "proxy:start": "portless proxy start",
    "proxy:stop": "portless proxy stop",
    "shadcn": "pnpm --filter=@mono/frontend exec shadcn",
    "sync": "moon sync",
    "sync-agents": "pnpm --filter=@mono/scripts sync-agents",
    "test": "pnpm typegen && pnpm -r run test",
    "typecheck": "pnpm typegen && tsc --build",
    "typegen": "pnpm --filter @mono/frontend exec react-router typegen"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "cerato": "0.0.4"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.11",
    "portless": "0.13.0",
    "typescript": "5.9.3"
  }
}
