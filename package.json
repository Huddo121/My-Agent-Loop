{
  "name": "my-agent-loop",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "type": "module",
  "packageManager": "pnpm@10.8.0",
  "scripts": {
    "check": "biome check .",
    "check:fix": "biome check . --write",
    "dev": "moon :dev",
    "docker:build": "pnpm driver:build:linux && docker build -t my-agent-loop .",
    "driver:build": "moon driver:build",
    "driver:build:bundle": "moon driver:build-bundle",
    "driver:build:linux": "moon driver:build-linux",
    "driver:build:sea": "moon driver:build-sea",
    "drizzle": "pnpm run --filter @mono/server drizzle",
    "shadcn": "pnpm --filter=@mono/frontend exec shadcn",
    "sync": "moon sync",
    "sync-agents": "pnpm --filter=@mono/scripts sync-agents",
    "typecheck": "tsc --build"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "cerato": "0.0.4"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.11",
    "typescript": "5.9.3"
  }
}
